wan_json_raw() {
	# Fetch external IPs in parallel to avoid sequential timeout stacking
	ext_ip_wan1=""; ext_ip_wan2=""
	tmpdir=$(mktemp -d)
	dev1=$(ubus call network.interface.wan1 status 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null)
	dev2=$(ubus call network.interface.wan2 status 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null)
	[ -n "$dev1" ] && curl -s --interface "$dev1" --max-time 4 https://api.ipify.org > "$tmpdir/wan1" 2>/dev/null &
	[ -n "$dev2" ] && curl -s --interface "$dev2" --max-time 4 https://api.ipify.org > "$tmpdir/wan2" 2>/dev/null &
	wait
	ext_ip_wan1=$(cat "$tmpdir/wan1" 2>/dev/null)
	ext_ip_wan2=$(cat "$tmpdir/wan2" 2>/dev/null)
	isp_wan1=""; isp_wan2=""
	[ -n "$ext_ip_wan1" ] && curl -s --max-time 3 "https://ipinfo.io/$ext_ip_wan1/org" > "$tmpdir/isp1" 2>/dev/null &
	[ -n "$ext_ip_wan2" ] && curl -s --max-time 3 "https://ipinfo.io/$ext_ip_wan2/org" > "$tmpdir/isp2" 2>/dev/null &
	wait
	raw_isp1=$(cat "$tmpdir/isp1" 2>/dev/null)
	raw_isp2=$(cat "$tmpdir/isp2" 2>/dev/null)
	# Only use the response if it's a plain text ISP name (starts with AS), not a JSON error
	case "$raw_isp1" in AS*) isp_wan1=$(echo "$raw_isp1" | sed 's/^AS[0-9]* //' | tr -d '\n"\\') ;; *) isp_wan1="" ;; esac
	case "$raw_isp2" in AS*) isp_wan2=$(echo "$raw_isp2" | sed 's/^AS[0-9]* //' | tr -d '\n"\\') ;; *) isp_wan2="" ;; esac
	rm -rf "$tmpdir"

	printf '{'
	first=1
	for iface in wan1 wan2; do
		status=$(ubus call network.interface.$iface status 2>/dev/null)
		[ -z "$status" ] && continue
		up=$(echo "$status" | jsonfilter -e '@.up')
		uptime=$(echo "$status" | jsonfilter -e '@.uptime')
		proto=$(echo "$status" | jsonfilter -e '@.proto')
		device=$(echo "$status" | jsonfilter -e '@.l3_device')
		metric=$(echo "$status" | jsonfilter -e '@.metric')
		addr=$(echo "$status" | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null)
		gw=$(echo "$status" | jsonfilter -e '@.route[0].nexthop' 2>/dev/null)
		case "$iface" in
			wan1) ext_ip="$ext_ip_wan1"; isp="$isp_wan1" ;;
			wan2) ext_ip="$ext_ip_wan2"; isp="$isp_wan2" ;;
		esac
		rx=0; tx=0
		if [ -d "/sys/class/net/$device" ]; then
			rx=$(cat /sys/class/net/$device/statistics/rx_bytes 2>/dev/null || echo 0)
			tx=$(cat /sys/class/net/$device/statistics/tx_bytes 2>/dev/null || echo 0)
		fi
		[ "$first" = 1 ] && first=0 || printf ','
		cat <<-EOF
		"$iface": {
			"up": $up,
			"uptime": ${uptime:-0},
			"proto": "$proto",
			"device": "${device:-unknown}",
			"metric": ${metric:-0},
			"address": "${addr:-}",
			"gateway": "${gw:-}",
			"external_ip": "${ext_ip:-}",
			"isp": "${isp:-}",
			"rx_bytes": $rx,
			"tx_bytes": $tx
		}
		EOF
	done
	printf '}'
}

get_wan_raw() {
	wan_json_raw
}


# ── POST handlers ───────────────────────────────────────────────────

handle_post_with_data() {
	POSTDATA="$1"
	action=$(echo "$POSTDATA" | jsonfilter -e '@.action' 2>/dev/null)
	case "$action" in
		adblock_reload)
			send_json
			/etc/init.d/adblock reload >/dev/null 2>&1 &
			echo '{"ok":true,"message":"adblock reload started"}'
			;;
		adblock_enable)
			send_json
			uci set adblock.global.adb_enabled='1'
			uci commit adblock
			/etc/init.d/adblock reload >/dev/null 2>&1 &
			echo '{"ok":true,"message":"adblock enabled"}'
			;;
		adblock_disable)
			send_json
			uci set adblock.global.adb_enabled='0'
			uci commit adblock
			/etc/init.d/adblock stop >/dev/null 2>&1 &
			echo '{"ok":true,"message":"adblock disabled"}'
			;;
		vpn_on)
			send_json
			if [ -x /usr/bin/vpn-toggle.sh ]; then
				/usr/bin/vpn-toggle.sh on >/dev/null 2>&1 &
				echo '{"ok":true,"message":"VPN turning on"}'
			else
				echo '{"ok":false,"message":"vpn-toggle.sh not found"}'
			fi
			;;
		vpn_off)
			send_json
			if [ -x /usr/bin/vpn-toggle.sh ]; then
				/usr/bin/vpn-toggle.sh off >/dev/null 2>&1 &
				echo '{"ok":true,"message":"VPN turning off"}'
			else
				echo '{"ok":false,"message":"vpn-toggle.sh not found"}'
			fi
			;;
		vpn_switch)
			send_json
			server_id=$(echo "$POSTDATA" | jsonfilter -e '@.server' 2>/dev/null)
			if [ -z "$server_id" ] || ! is_safe_id "$server_id"; then
				echo '{"ok":false,"message":"invalid server id"}'
				break
			fi
			conf_file="$SERVERS_DIR/$server_id.conf"
			if ! parse_conf "$conf_file"; then
				echo '{"ok":false,"message":"server not found"}'
				break
			fi
			new_name=$(server_name "$server_id")
			was_up=$(ubus call network.interface.wgvpn status 2>/dev/null | jsonfilter -e '@.up' 2>/dev/null)
			if [ "$was_up" = "true" ]; then
				ifdown wgvpn 2>/dev/null
				sleep 1
			fi
			uci set network.@wireguard_wgvpn[0].public_key="$_pubkey"
			uci set network.@wireguard_wgvpn[0].endpoint_host="$_endpoint"
			uci set network.@wireguard_wgvpn[0].endpoint_port="${_port:-51820}"
			uci commit network
			if [ "$was_up" = "true" ]; then
				ifup wgvpn 2>/dev/null &
			fi
			echo "{\"ok\":true,\"message\":\"Switched to $new_name\"}"
			;;
		wan_toggle)
			send_json
			iface=$(echo "$POSTDATA" | jsonfilter -e '@.iface' 2>/dev/null)
			state=$(echo "$POSTDATA" | jsonfilter -e '@.state' 2>/dev/null)
			case "$iface" in
				wan1|wan2) ;;
				*) echo '{"ok":false,"message":"invalid interface"}'; break ;;
			esac
			case "$state" in
				enable)
					ifup "$iface" 2>/dev/null
					mwan3 ifup "$iface" 2>/dev/null
					echo "{\"ok\":true,\"message\":\"${iface} enabled\"}"
					;;
				disable)
					mwan3 ifdown "$iface" 2>/dev/null
					ifdown "$iface" 2>/dev/null
					echo "{\"ok\":true,\"message\":\"${iface} disabled\"}"
					;;
				*) echo '{"ok":false,"message":"invalid state"}' ;;
			esac
			;;
		wan_weight)
			send_json
			if [ -x /usr/bin/wan-weight.sh ]; then
				/usr/bin/wan-weight.sh >/dev/null 2>&1 &
				echo '{"ok":true,"message":"WAN weight update started"}'
			else
				echo '{"ok":false,"message":"wan-weight.sh not found"}'
			fi
			;;
		check_updates)
			send_json
			apk update >/dev/null 2>&1
			count=$(apk upgrade --simulate 2>&1 | grep -c 'Upgrading\|Installing')
			echo "{\"ok\":true,\"message\":\"$count update(s) available\"}"
			;;
		install_updates)
			send_json
			apk update >/dev/null 2>&1
			result=$(apk upgrade 2>&1)
			count=$(echo "$result" | grep -c 'Upgrading\|Installing')
			echo "{\"ok\":true,\"message\":\"$count package(s) updated\"}"
			;;
		install_selected)
			send_json
			pkgs_raw=$(echo "$POSTDATA" | jsonfilter -e '@.packages[*]' 2>/dev/null)
			do_reboot=$(echo "$POSTDATA" | jsonfilter -e '@.reboot' 2>/dev/null)
			pkgs_safe=""
			for p in $pkgs_raw; do
				is_safe_id "$p" || continue
				pkgs_safe="$pkgs_safe $p"
			done
			if [ -z "$pkgs_safe" ]; then
				echo '{"ok":false,"message":"no valid packages selected"}'
				break
			fi
			apk update >/dev/null 2>&1
			result=$(apk add --upgrade $pkgs_safe 2>&1)
			count=$(echo "$result" | grep -c 'Upgrading\|Installing')
			if [ "$do_reboot" = "true" ]; then
				echo "{\"ok\":true,\"message\":\"$count package(s) updated. Rebooting...\"}"
				sleep 2 && reboot &
			else
				echo "{\"ok\":true,\"message\":\"$count package(s) updated\"}"
			fi
			;;
		install_updates_reboot)
			send_json
			apk update >/dev/null 2>&1
			apk upgrade >/dev/null 2>&1
			echo '{"ok":true,"message":"Updates installed. Rebooting..."}'
			sleep 2 && reboot &
			;;
		reboot)
			send_json
			echo '{"ok":true,"message":"Rebooting in 2 seconds..."}'
			sleep 2 && reboot &
			;;
		change_password)
			send_json
			cur_pass=$(echo "$POSTDATA" | jsonfilter -e '@.current_password' 2>/dev/null)
			new_pass=$(echo "$POSTDATA" | jsonfilter -e '@.new_password' 2>/dev/null)
			if [ -z "$cur_pass" ] || [ -z "$new_pass" ]; then
				echo '{"ok":false,"message":"Missing fields"}'
				break
			fi
			stored=$(cat "$CRED_FILE" 2>/dev/null)
			expected_user=$(echo "$stored" | cut -d: -f1)
			if ! verify_password "$expected_user" "$cur_pass"; then
				echo '{"ok":false,"message":"Current password is incorrect"}'
				break
			fi
			if [ ${#new_pass} -lt 4 ]; then
				echo '{"ok":false,"message":"New password must be at least 4 characters"}'
				break
			fi
			new_salt=$(head -c 16 /dev/urandom | hexdump -e '16/1 "%02x"')
			new_hash=$(hash_password "$new_salt" "$new_pass")
			printf '%s:%s:%s\n' "$expected_user" "$new_salt" "$new_hash" > "$CRED_FILE"
			chmod 600 "$CRED_FILE"
			cur_token=$(echo "$HTTP_COOKIE" | sed -n 's/.*sysauth=\([a-f0-9]*\).*/\1/p')
			invalidate_all_sessions "$cur_token"
			echo '{"ok":true,"message":"Password changed"}'
			;;
		*)
			send_error "unknown action: $action"
			;;
	esac
}

# ── Auth ────────────────────────────────────────────────────────────
# Credentials file format: username:salt:hash
# Hash = sha256(salt:password)

CRED_FILE="/etc/piadmin/credentials"
SESSION_DIR="/tmp/piadmin-sessions"
FAIL_DIR="/tmp/piadmin-fails"
MAX_FAILS=5
LOCKOUT_SECS=60

send_401() {
	printf 'Status: 401 Unauthorized\r\nContent-Type: application/json\r\n%b\r\n\r\n' "$SEC_HDRS"
	echo '{"error":"unauthorized"}'
	exit 0
}

check_auth() {
	token=$(echo "$HTTP_COOKIE" | sed -n 's/.*sysauth=\([a-f0-9]*\).*/\1/p')
	[ -z "$token" ] && send_401
	is_safe_id "$token" || send_401
	[ ! -f "$SESSION_DIR/$token" ] && send_401
	created=$(cat "$SESSION_DIR/$token" 2>/dev/null)
	now=$(date +%s)
	elapsed=$(( now - created ))
	if [ "$elapsed" -gt 86400 ]; then
		rm -f "$SESSION_DIR/$token"
		send_401
	fi
}

check_brute_force() {
	mkdir -p "$FAIL_DIR"
	client_ip=$(echo "$REMOTE_ADDR" | sed 's/[^a-fA-F0-9.]/_/g')
	fail_file="$FAIL_DIR/$client_ip"
	if [ -f "$fail_file" ]; then
		fail_count=$(sed -n '1p' "$fail_file")
		fail_time=$(sed -n '2p' "$fail_file")
		now=$(date +%s)
		elapsed=$((now - fail_time))
		if [ "$fail_count" -ge "$MAX_FAILS" ] && [ "$elapsed" -lt "$LOCKOUT_SECS" ]; then
			send_json
			echo '{"ok":false,"message":"Too many attempts. Try again later."}'
			exit 0
		fi
		if [ "$elapsed" -ge "$LOCKOUT_SECS" ]; then
			rm -f "$fail_file"
		fi
	fi
}

record_fail() {
	mkdir -p "$FAIL_DIR"
	client_ip=$(echo "$REMOTE_ADDR" | sed 's/[^a-fA-F0-9.]/_/g')
	fail_file="$FAIL_DIR/$client_ip"
	if [ -f "$fail_file" ]; then
		prev=$(sed -n '1p' "$fail_file")
		count=$((prev + 1))
	else
		count=1
	fi
	printf '%d\n%d\n' "$count" "$(date +%s)" > "$fail_file"
}

clear_fails() {
	client_ip=$(echo "$REMOTE_ADDR" | sed 's/[^a-fA-F0-9.]/_/g')
	rm -f "$FAIL_DIR/$client_ip"
}

verify_password() {
	_user="$1"; _pass="$2"
	stored=$(cat "$CRED_FILE" 2>/dev/null)
	expected_user=$(echo "$stored" | cut -d: -f1)
	stored_salt=$(echo "$stored" | cut -d: -f2)
	stored_hash=$(echo "$stored" | cut -d: -f3)
	[ "$_user" != "$expected_user" ] && return 1
	computed=$(hash_password "$stored_salt" "$_pass")
	[ "$computed" = "$stored_hash" ]
}

gen_token() {
	head -c 32 /dev/urandom | hexdump -e '32/1 "%02x"'
}

set_auth_cookie() {
	printf 'Set-Cookie: sysauth=%s; Path=/; Max-Age=86400; SameSite=Strict; HttpOnly; Secure' "$1"
}

invalidate_all_sessions() {
	_keep="$1"
	for f in "$SESSION_DIR"/*; do
		[ -f "$f" ] || continue
		[ "$(basename "$f")" = "$_keep" ] && continue
		rm -f "$f"
	done
}

cleanup_stale_sessions() {
	now=$(date +%s)
	for f in "$SESSION_DIR"/*; do
		[ -f "$f" ] || continue
		created=$(cat "$f" 2>/dev/null)
		[ -z "$created" ] && { rm -f "$f"; continue; }
		elapsed=$((now - created))
		[ "$elapsed" -gt 86400 ] && rm -f "$f"
	done
}

# ── Router ──────────────────────────────────────────────────────────

case "$REQUEST_METHOD" in
	GET)
		check_auth
		section=$(echo "$QUERY_STRING" | sed -n 's/.*section=\([a-z0-9]*\).*/\1/p')
		case "$section" in
			system)  get_system ;;
			wan)     get_wan ;;
			mwan3)   get_mwan3 ;;
			adblock) get_adblock ;;
			dns)     get_dns ;;
			vpn)     get_vpn ;;
			updates) get_updates ;;
			all)     get_all ;;
			*)       send_error ;;
		esac
		;;
	POST)
		read -r POSTDATA
		action=$(echo "$POSTDATA" | jsonfilter -e '@.action' 2>/dev/null)
		case "$action" in
			login)
				check_brute_force
				cleanup_stale_sessions
				user=$(echo "$POSTDATA" | jsonfilter -e '@.username' 2>/dev/null)
				pass=$(echo "$POSTDATA" | jsonfilter -e '@.password' 2>/dev/null)
				if [ -z "$user" ] || [ -z "$pass" ]; then
					send_json; echo '{"ok":false,"message":"missing credentials"}'; exit 0
				fi
				if verify_password "$user" "$pass"; then
					clear_fails
					mkdir -p "$SESSION_DIR"
					token=$(gen_token)
					echo "$(date +%s)" > "$SESSION_DIR/$token"
					printf 'Content-Type: application/json\r\n%b\r\n%s\r\n\r\n' "$SEC_HDRS" "$(set_auth_cookie "$token")"
					echo '{"ok":true}'
				else
					record_fail
					sleep 1
					send_json; echo '{"ok":false,"message":"invalid credentials"}'
				fi
				exit 0
				;;
			logout)
				token=$(echo "$HTTP_COOKIE" | sed -n 's/.*sysauth=\([a-f0-9]*\).*/\1/p')
				[ -n "$token" ] && is_safe_id "$token" && rm -f "$SESSION_DIR/$token"
				printf 'Content-Type: application/json\r\n%b\r\nSet-Cookie: sysauth=; Path=/; Max-Age=0; Secure\r\n\r\n' "$SEC_HDRS"
				echo '{"ok":true}'
				exit 0
				;;
		esac
		check_auth
		handle_post_with_data "$POSTDATA"
		;;
	*)
		send_error
		;;
esac

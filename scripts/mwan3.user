#!/bin/sh
# /etc/mwan3.user — sourced by mwan3 on every interface tracking event.
#
# Purpose: re-handshake the WireGuard tunnel over the surviving WAN on a WAN
# transition. WireGuard pins its client UDP source port regardless of mwan3 WAN
# state, so the tunnel's conntrack entry is sticky and will NOT migrate cleanly
# when the active WAN dies — without this flush the tunnel black-holes on the
# dead uplink (docs/reference/vpn.md §10, requirements FR-V11).
#
# mwan3 exports $ACTION (ifup|ifdown|connected|disconnected) and $INTERFACE (the
# WAN). Requires the `conntrack-tools` package (provides the `conntrack` CLI).
#
# Race note: this hook shares NO mutable state with vpn-toggle.sh except the
# kernel conntrack table — it never writes UCI, never runs ifup/ifdown, never
# touches pbr. Its worst case under any toggle/flap interleaving is one wasted,
# idempotent flush (docs/reference/vpn.md §10).

case "${ACTION}" in
    ifdown|disconnected|connected)
        # Resolve the tunnel's UDP port from the live wg config rather than
        # hardcoding 51820 (FR-V11): a mismatched port flushes nothing and tunnel
        # failover silently breaks. Prefer the running peer endpoint port; fall
        # back to the UCI peer config, then to the Surfshark default 51820.
        wg_port="$(wg show wgvpn endpoints 2>/dev/null \
                   | awk 'NR==1 { n = split($2, a, ":"); print a[n] }')"
        # Reject a non-numeric result (e.g. a malformed/hostname endpoint field)
        # so the fallback chain fires rather than handing conntrack a garbage port.
        case "${wg_port}" in *[!0-9]*|"") wg_port="" ;; esac
        [ -n "${wg_port}" ] || wg_port="$(uci -q get network.wgpeer.endpoint_port)"
        case "${wg_port}" in *[!0-9]*|"") wg_port="" ;; esac
        [ -n "${wg_port}" ] || wg_port=51820

        # Flush ONLY the WireGuard endpoint flow, not all conntrack — flushing
        # everything would reset every active TCP download. Both directions:
        # --dport for the outbound flow, --sport for the NAT reply side, so the
        # re-handshake is forced regardless of which half conntrack indexed. Each
        # -D is idempotent: deleting an absent flow is a harmless no-op.
        conntrack -D -p udp --dport "${wg_port}" 2>/dev/null || true
        conntrack -D -p udp --sport "${wg_port}" 2>/dev/null || true
        logger -t mwan3.user "flushed WG conntrack (udp/${wg_port}) on ${ACTION} (${INTERFACE})"
        ;;
esac
